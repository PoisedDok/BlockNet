{
  "name": "@blocknet/core",
  "version": "0.0.0",
  "private": true,
  "description": "BlockNet's analysis engine: block detection, import edges, risk checks. Zero VS Code dependencies.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "blocknet": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "pretest": "npm run build",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "tsup": "^8.5.1",
    "vitest": "^4.1.10"
  }
}
